PYTHONPATH=src
LOG_LEVEL=DEBUG
CPAIOPS_LOG_LEVEL=INFO

# MOCK_DATA=mock_data.yaml

SESSION_TIMEOUT=1800

# WebUI Configuration
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8080
WEBUI_SESSION_AGE_HOURS=8
WEBUI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:8080,http://localhost:8080
DATABASE_URL=sqlite+aiosqlite:///_tmp/cache.db

# FPCR Create & Verify flow configuration
# Path to CSV file with engineer initials mapping (ENGINEER_INITIALS,FirstName,LastName,Email)
WEBUI_INITIALS_CSV_PATH=_tmp/FWTeam_admins.csv

# Directory for Jinja2 evidence templates
WEBUI_EVIDENCE_TEMPLATE_DIR=src/fa/templates

# Timeout for PDF rendering (seconds)
WEBUI_PDF_RENDER_TIMEOUT=30

# Whether to auto-create missing objects when not found
WEBUI_OBJECT_CREATE_MISSING=True

# Whether to prefer objects matching naming convention
WEBUI_OBJECT_PREFER_CONVENTION=True

# Whether to disable rules after creation
WEBUI_RULE_DISABLE_AFTER_CREATE=True

# Whether to verify policy after rule creation
WEBUI_RULE_VERIFY_AFTER_CREATE=True
