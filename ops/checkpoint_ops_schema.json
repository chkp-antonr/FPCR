        { "$ref": "#/definitions/group_delete" },
        { "$ref": "#/definitions/group_show" },
        { "$ref": "#/definitions/access_rule_add" },
        { "$ref": "#/definitions/access_rule_update" },
        { "$ref": "#/definitions/access_rule_delete" },
        { "$ref": "#/definitions/access_rule_show" },
        { "$ref": "#/definitions/nat_rule_add" },
        { "$ref": "#/definitions/nat_rule_update" },
        { "$ref": "#/definitions/nat_rule_delete" },
        { "$ref": "#/definitions/nat_rule_show" },
        { "$ref": "#/definitions/threat_rule_add" },
        { "$ref": "#/definitions/https_rule_add" }
      ]
