    "threat_rule_data": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "enabled": { "type": "boolean" },
        "comments": { "type": "string" },
        "source": { "type": "array", "items": { "type": "string" } },
        "destination": { "type": "array", "items": { "type": "string" } },
        "service": { "type": "array", "items": { "type": "string" } },
        "protected-scope": { "type": "array", "items": { "type": "string" } },
        "action": { "type": "string" },
        "track": { "$ref": "#/definitions/track_settings" },
        "install-on": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "https_rule_data": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "enabled": { "type": "boolean" },
        "comments": { "type": "string" },
        "source": { "type": "array", "items": { "type": "string" } },
        "destination": { "type": "array", "items": { "type": "string" } },
        "service": { "type": "array", "items": { "type": "string" } },
        "site-category": { "type": "array", "items": { "type": "string" } },
        "action": { "type": "string" },
        "track": { "$ref": "#/definitions/track_settings" },
        "blade": { "type": "array", "items": { "type": "string" } },
        "certificate": { "type": "string" },
        "install-on": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "nat_settings": {
      "description": "NAT (Network Address Translation) settings for hosts, networks, and address ranges",
      "type": "object",
      "properties": {
        "method": {
          "description": "NAT method: static (1:1 IP translation) or hide (behind gateway)",
          "type": "string",
          "enum": ["static", "hide"]
        },
        "ipv4-address": {
          "description": "Translated IPv4 address for static NAT",
          "type": "string"
        },
        "ipv6-address": {
          "description": "Translated IPv6 address for static NAT",
          "type": "string"
        },
        "gateway": {
          "description": "Gateway name for hide NAT",
          "type": "string"
        },
        "hide-behind": {
          "description": "Method to hide behind (gateway or ip-address). Forbidden if method is static",
          "type": "string",
          "enum": ["gateway", "ip-address"]
        },
        "install-on": {
          "description": "Gateway where NAT rule should be installed",
          "type": "string"
        },
        "auto-rule": {
          "description": "Enable/disable automatic NAT rule creation",
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "operation": {
      "type": "object",
