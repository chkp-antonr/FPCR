        "service": { "type": "array", "items": { "type": "string" } },
        "method": { "type": "string" },
        "translated-source": { "type": "string" },
        "translated-destination": { "type": "string" },
        "translated-service": { "type": "string" },
        "install-on": { "type": "array", "items": { "type": "string" } }
